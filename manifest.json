{
  "manifest_version": 3,
  "name": "ZeroTrace – Ad & Tracker Blocker",
  "version": "1.0.0",
  "permissions": ["declarativeNetRequest", "scripting", "storage", "tabs", "webRequest"],
  "action": {
    "default_title": "ZeroTrace – Ad & Tracker Blocker",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtube-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtube-ads.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
